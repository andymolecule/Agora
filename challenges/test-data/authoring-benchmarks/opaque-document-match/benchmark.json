{
  "id": "opaque-document-match",
  "authoring_path_support": "definition_backed_executable",
  "intent_family": "exact_artifact_match",
  "artifacts_root": "uploads",
  "prompt_variants_root": "prompt-variants",
  "solver_submissions_root": "solver-submissions",
  "compile_invariants": {
    "preset_id": "exact_artifact_match",
    "backend_kind": "generated_scorer",
    "execution_runtime_family": "reproducibility",
    "evaluator_archetype": "exact_artifact_match",
    "metric": "exact_match",
    "artifact_roles": [
      {
        "file_name": "source_packet.pdf",
        "role": "public_inputs",
        "visibility": "public"
      },
      {
        "file_name": "reference_output.pdf",
        "role": "hidden_reference",
        "visibility": "private"
      }
    ],
    "submission_contract": {
      "kind": "opaque_file",
      "extension": ".pdf",
      "mime": "application/pdf"
    }
  },
  "acceptable_compile_states": ["needs_review"],
  "disallowed_outcomes": {
    "preset_ids": [
      "tabular_regression",
      "tabular_classification",
      "ranking",
      "docking",
      "reproducibility"
    ],
    "recommended_actions": ["send_to_expert_mode"]
  },
  "prompt_variants": [
    {
      "id": "direct-poster-brief",
      "file": "prompt-variants/direct-poster-brief.md",
      "acceptable_compile_states": ["needs_review"],
      "expected_follow_up_topics": [
        "confirm exact-match winning rule",
        "public versus hidden artifact split",
        "reward",
        "distribution",
        "submission window"
      ]
    },
    {
      "id": "ops-thread-brief",
      "file": "prompt-variants/ops-thread-brief.md",
      "acceptable_compile_states": ["needs_review"],
      "expected_follow_up_topics": [
        "which PDF stays hidden",
        "what exact match means for the document",
        "reward",
        "distribution"
      ]
    },
    {
      "id": "minimal-brief",
      "file": "prompt-variants/minimal-brief.md",
      "acceptable_compile_states": ["needs_review"],
      "expected_follow_up_topics": [
        "submission artifact format",
        "hidden reference artifact",
        "reward",
        "submission window"
      ]
    }
  ]
}
