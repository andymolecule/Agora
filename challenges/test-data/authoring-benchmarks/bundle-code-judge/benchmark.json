{
  "id": "bundle-code-judge",
  "authoring_path_support": "definition_backed_typed",
  "intent_family": "bundle_or_code_judge",
  "artifacts_root": "uploads",
  "prompt_variants_root": "prompt-variants",
  "solver_submissions_root": "solver-submissions",
  "compile_invariants": {
    "preset_id": "bundle_or_code_judge",
    "backend_kind": "definition_only",
    "execution_runtime_family": null,
    "evaluator_archetype": "bundle_or_code_judge",
    "metric": "custom",
    "artifact_roles": [
      {
        "file_name": "public_inputs_bundle.zip",
        "role": "public_inputs",
        "visibility": "public"
      },
      {
        "file_name": "hidden_rubric.json",
        "role": "hidden_reference",
        "visibility": "private"
      }
    ],
    "submission_contract": {
      "kind": "opaque_file",
      "extension": ".zip",
      "mime": "application/zip"
    }
  },
  "acceptable_compile_states": ["needs_review"],
  "disallowed_outcomes": {
    "preset_ids": [
      "tabular_regression",
      "tabular_classification",
      "ranking",
      "docking",
      "reproducibility"
    ],
    "recommended_actions": ["approve_after_review"]
  },
  "prompt_variants": [
    {
      "id": "direct-poster-brief",
      "file": "prompt-variants/direct-poster-brief.md",
      "acceptable_compile_states": ["needs_review"],
      "expected_follow_up_topics": [
        "judge rubric",
        "required bundle contents",
        "public versus hidden artifact split",
        "reward"
      ]
    },
    {
      "id": "ops-thread-brief",
      "file": "prompt-variants/ops-thread-brief.md",
      "acceptable_compile_states": ["needs_review"],
      "expected_follow_up_topics": [
        "how the bundle is judged",
        "what stays hidden",
        "submission window"
      ]
    },
    {
      "id": "minimal-brief",
      "file": "prompt-variants/minimal-brief.md",
      "acceptable_compile_states": ["needs_review"],
      "expected_follow_up_topics": [
        "zip submission format",
        "deterministic judging rule",
        "reward"
      ]
    }
  ]
}
