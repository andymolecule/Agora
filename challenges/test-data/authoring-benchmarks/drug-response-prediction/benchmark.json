    "recommended_actions": ["send_to_expert_mode"]
  },
  "prompt_variants": [
    {
      "id": "direct-poster-brief",
      "file": "prompt-variants/direct-poster-brief.md",
      "acceptable_compile_states": ["ready", "needs_review"],
      "expected_follow_up_topics": [
        "winning condition",
        "reward",
        "distribution",
        "submission window",
        "dispute window"
      ]
    },
    {
      "id": "ambiguous-biology-brief",
      "file": "prompt-variants/ambiguous-biology-brief.md",
      "acceptable_compile_states": ["ready", "needs_review"],
      "expected_follow_up_topics": [
        "winning condition",
        "confirm hidden labels remain private",
        "reward",
        "distribution",
        "submission window"
      ]
    },
    {
      "id": "minimal-slack-style-brief",
      "file": "prompt-variants/minimal-slack-style-brief.md",
      "acceptable_compile_states": ["needs_review", "ready"],
      "expected_follow_up_topics": [
        "what a winning result means",
        "which uploaded file contains hidden labels",
        "reward",
        "distribution",
        "submission window"
      ]
    }
