    "metric": "r2",
    "artifact_roles": [
      {
        "file_name": "drug_response_train.csv",
        "role": "training_data",
        "visibility": "public"
      },
      {
        "file_name": "drug_response_holdout.csv",
        "role": "evaluation_features",
        "visibility": "public"
      },
      {
        "file_name": "heldout_response_labels.csv",
        "role": "hidden_labels",
        "visibility": "private"
      }
    ],
    "submission_contract": {
      "kind": "csv_table",
      "required_columns": ["id", "prediction"],
      "id_column": "id",
      "value_column": "prediction"
    }
